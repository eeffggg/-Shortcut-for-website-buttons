{
  "author": "eeffggg",
  "homepage_url": "https://github.com/eeffggg/-Shortcut-for-website-buttons/"
  "manifest_version": 3,
  "name": "Grok 多快捷键增强版",
  "version": "2.1",
  "description": "任意网页 + 任意快捷键（在 shortcuts 页面自由设置）",
  "permissions": ["activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "commands": {
    "action-1": {"description": "Grok新建对话" },
    "action-2": {"description": "Grok历史记录" },

	
    "action-999": {"description": "示例,不要改动此行,只需要复制上面(action-1)的任意一行(改后面数字),然后将双引号内内容修改为你想要的,它仅作为名字使用" }
  }
}
